{
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput --clear && cp -r media/* staticfiles/media/ 2>/dev/null || true",
  "framework": "django",
"installCommand": "pip install -r requirements.txt --only-binary=psycopg",
  "outputDirectory": "Blog",
  "version": 2,
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/media/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/media/(.*)",
      "dest": "Blog/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Blog/api/index.py"
    }
  ]
}
