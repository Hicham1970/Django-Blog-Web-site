{
  "version": 2,
  "functions": {
    "vercel_app.py": {
      "runtime": "vercel-python@0.6.1"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/vercel_app.py"
    }
  ]
}
